"""Grounded source-semantic profile builder — V3 dominance arbitration.

Invariants:
- exact source text is the only semantic input;
- canonical mechanism names are language-neutral;
- every mechanism is backed by exact validated source spans;
- CONTROL_MODIFIER never becomes a primary type;
- primary type is selected by role-aware domain dominance;
- EN / FR / AR pipeline aliases canonicalize to the same ontology;
- uncertainty abstains as UNKNOWN;
- publication-gate code is not imported or modified.
"""
from __future__ import annotations

import hashlib
import json
import re
import unicodedata
from dataclasses import dataclass
from typing import Any, Iterable

UNKNOWN = "UNKNOWN"

DOMAIN_CORE = "DOMAIN_CORE"
DOMAIN_SECONDARY = "DOMAIN_SECONDARY"
GENERIC_SECONDARY = "GENERIC_SECONDARY"
CONTROL_MODIFIER = "CONTROL_MODIFIER"
PROCEDURAL_STATE = "PROCEDURAL_STATE"

PRIMARY_ROLES = {DOMAIN_CORE, DOMAIN_SECONDARY, PROCEDURAL_STATE}

@dataclass(frozen=True)
class MechanismRule:
    kind: str
    patterns: dict[str, tuple[str, ...]]
    rank: int
    primary_type: str
    semantic_role: str
    primary_eligible: bool = False
    polarity: str | None = None
    procedural_state: str | None = None

def _r(kind, en, fr, ar, rank, primary, role, eligible=True, polarity=None, state=None):
    return MechanismRule(
        kind,
        {"en": tuple(en), "fr": tuple(fr), "ar": tuple(ar)},
        rank, primary, role, eligible, polarity, state,
    )

RULES: tuple[MechanismRule, ...] = (
    _r("PRIOR_CONSENT_PREREQUISITE",
       (r"\bwithout\b.{0,120}\bprior\s+(?:written\s+)?(?:consent|approval)\b", r"\bprior\s+written\s+(?:consent|approval)\b"),
       (r"\bsans\b.{0,120}\b(?:consentement|approbation)\b.{0,40}\bpr[eé]alable\b", r"\b(?:consentement|approbation)\s+[eé]crit(?:e)?\s+pr[eé]alable\b"),
       (r"(?:دون|بدون).{0,120}(?:موافقة|الموافقة).{0,50}(?:مسبق|المسبقة)", r"(?:الموافقة|موافقة).{0,30}(?:الخطية|المكتوبة)?.{0,20}(?:المسبقة|مسبق)"),
