def _hash_json(value: Any) -> str:
    payload = json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()

def _normalize_for_language_detection(text: str) -> str:
    return unicodedata.normalize("NFKC", str(text or ""))

def detect_source_language(text: str) -> str:
    value = _normalize_for_language_detection(text)
    if re.search(r"[\u0600-\u06FF]", value):
        return "ar"
    if re.search(r"[àâçéèêëîïôùûüÿœæ]", value.lower()):
        return "fr"
    markers = re.findall(r"\b(?:le|la|les|des|une|du|aux|doit|sans|droit|délai|contrat|partie)\b", value.lower())
    return "fr" if len(markers) >= 3 else "en"

def _evidence(source: str, pattern: str, label: str) -> Iterable[dict]:
    for match in re.finditer(pattern, source, re.IGNORECASE | re.DOTALL):
        yield {"label": label, "start": match.start(), "end": match.end(), "text": match.group(0)}

def _valid_span(source: str, span: dict) -> bool:
    start, end, text = span.get("start"), span.get("end"), span.get("text")
    return isinstance(start, int) and isinstance(end, int) and 0 <= start < end <= len(source) and source[start:end] == text

def _mandatory_arguments(span_text: str, language: str) -> list[dict]:
    if language == "ar":
        parts = re.split(r"\s+و(?=[\u0600-\u06FF])|،", span_text)
    elif language == "fr":
        parts = re.split(r"\s+et\s+", span_text, flags=re.IGNORECASE)
    else:
        parts = re.split(r"\s+and\s+", span_text, flags=re.IGNORECASE)
    result = []
    for part in parts:
        tokens = re.findall(r"[^\W\d_]{3,}", part.lower(), flags=re.UNICODE)
        if tokens:
            result.append({"text": part.strip(), "tokens": tokens[:20]})
    return result if len(result) >= 2 else []

def extract_source_mechanisms(source_text: str, language: str | None = None) -> list[dict]:
    source = str(source_text or "")
    lang = language or detect_source_language(source)
    mechanisms: list[dict] = []
    for rule in RULES:
        spans: list[dict] = []
        for pattern in rule.patterns.get(lang, ()):
            spans.extend(_evidence(source, pattern, rule.kind))
        unique, seen = [], set()
        for span in spans:
            key = (span["start"], span["end"], span["label"])
            if key not in seen and _valid_span(source, span):
                seen.add(key)
                unique.append(span)
        if not unique:
            continue
        item: dict[str, Any] = {
            "kind": rule.kind,
            "rank": rule.rank,
            "candidate_primary_type": canonicalize_pipeline_type(rule.primary_type),
            "semantic_role": rule.semantic_role,
            "primary_eligible": rule.primary_eligible,
            "source_evidence": unique,
            "grounded": True,
        }
        if rule.polarity:
            item["polarity"] = rule.polarity
        if rule.procedural_state:
            item["procedural_state"] = rule.procedural_state
        if rule.kind == "MANDATORY_CONJUNCTION":
            args = _mandatory_arguments(unique[0]["text"], lang)
            if args:
                item["arguments"] = args
            else:
                item["kind"] = "MANDATORY_OBLIGATION"
                item["rank"] = 72
        mechanisms.append(item)
    return mechanisms

def attach_source_evidence(source_text: str, mechanisms: list[dict]) -> list[dict]:
    source = str(source_text or "")
    grounded = []
    for mechanism in mechanisms:
        valid = [s for s in mechanism.get("source_evidence") or [] if isinstance(s, dict) and _valid_span(source, s)]
        if not valid:
            continue
        item = dict(mechanism)
        item["source_evidence"] = valid
        item["grounded"] = True
        item["evidence_hash"] = _hash_json(valid)
        grounded.append(item)
    return grounded

def ground_mechanisms(source_text: str, mechanisms: list[dict]) -> list[dict]:
    return attach_source_evidence(source_text, mechanisms)

def rank_material_mechanisms(grounded_mechanisms: list[dict]) -> list[dict]:
    material = [
        dict(m) for m in grounded_mechanisms
        if m.get("grounded") is True and m.get("source_evidence") and int(m.get("rank", 0)) >= 70
    ]

    specific_termination_kinds = {
        "TERMINATION_FOR_CAUSE",
        "TERMINATION_FOR_CONVENIENCE",
        "IMMEDIATE_TERMINATION",
        "NON_PAYMENT_TERMINATION",
        "AUTOMATIC_EVENT_TRANSITION",
    }
    has_specific_termination = any(
        str(mechanism.get("kind") or "") in specific_termination_kinds
        for mechanism in material
    )
    if has_specific_termination:
        material = [
            mechanism
            for mechanism in material
            if str(mechanism.get("kind") or "") != "TERMINATION_RIGHT"
        ]

    material.sort(key=lambda m: (-int(m.get("rank", 0)), str(m.get("kind", "")), int(m["source_evidence"][0]["start"])))
    return material

def _merged_coverage(mechanisms: list[dict], source_length: int) -> float:
    if source_length <= 0:
        return 0.0
    intervals = []
    for mechanism in mechanisms:
        for span in mechanism.get("source_evidence") or []:
            start, end = int(span.get("start", 0)), int(span.get("end", 0))
            if end > start:
                intervals.append((start, end))
    if not intervals:
        return 0.0
    intervals.sort()
    merged: list[list[int]] = []
    for start, end in intervals:
        if not merged or start > merged[-1][1]:
            merged.append([start, end])
        else:
            merged[-1][1] = max(merged[-1][1], end)
    return min(1.0, sum(end - start for start, end in merged) / source_length)

def _independent_support(mechanisms: list[dict]) -> int:
    kinds = {str(m.get("kind", "")) for m in mechanisms}
    return len(kinds)

def derive_primary_type_from_ranked_mechanisms(ranked_mechanisms: list[dict], *, source_length: int = 0) -> dict:
    eligible = [
        m for m in ranked_mechanisms
        if m.get("primary_eligible") is True and m.get("semantic_role") in PRIMARY_ROLES
    ]
    if not eligible:
        return {
            "primary_type": UNKNOWN, "confidence": 0.0, "supporting_mechanisms": [],
            "abstained": True, "abstention_reason": "NO_PRIMARY_ELIGIBLE_DOMAIN_MECHANISM",
            "dominance_scores": [],
        }

    grouped: dict[str, list[dict]] = {}
    for mechanism in eligible:
        candidate = canonicalize_pipeline_type(mechanism.get("candidate_primary_type"))
        if candidate and candidate != UNKNOWN.lower():
            grouped.setdefault(candidate, []).append(mechanism)

    scored = []
    for candidate, mechanisms in grouped.items():
        coverage = _merged_coverage(mechanisms, source_length)
        independent = _independent_support(mechanisms)
        core_count = sum(m.get("semantic_role") == DOMAIN_CORE for m in mechanisms)
        secondary_count = sum(m.get("semantic_role") == DOMAIN_SECONDARY for m in mechanisms)
        procedural_count = sum(m.get("semantic_role") == PROCEDURAL_STATE for m in mechanisms)
        rank_signal = max(int(m.get("rank", 0)) for m in mechanisms) / 100.0
        role_signal = sum(ROLE_WEIGHT.get(str(m.get("semantic_role")), 0.0) for m in mechanisms)
        support_signal = min(22.0, max(0, independent - 1) * 11.0)
        coverage_signal = coverage * 42.0
        score = role_signal + support_signal + coverage_signal + rank_signal * 12.0
        scored.append({
            "type": candidate,
            "score": round(score, 4),
            "coverage": round(coverage, 4),
            "independent_support": independent,
            "core_count": core_count,
            "secondary_count": secondary_count,
            "procedural_count": procedural_count,
            "mechanisms": mechanisms,
        })

    scored.sort(key=lambda x: (-x["score"], -x["coverage"], x["type"]))
    winner = scored[0]
    runner = scored[1] if len(scored) > 1 else None
    margin = winner["score"] - runner["score"] if runner else winner["score"]

    enough_domain_mass = (
        winner["core_count"] >= 1 and winner["coverage"] >= 0.16
    ) or winner["independent_support"] >= 2 or (
        winner["procedural_count"] >= 1 and winner["coverage"] >= 0.22
    )
    enough_dominance = runner is None or margin >= 8.0 or winner["score"] >= runner["score"] * 1.18

    public_scores = [
        {k: v for k, v in item.items() if k != "mechanisms"}
        for item in scored
    ]

    if not enough_domain_mass:
        return {
            "primary_type": UNKNOWN,
            "confidence": round(min(0.79, 0.42 + winner["coverage"]), 4),
            "supporting_mechanisms": [m["kind"] for m in winner["mechanisms"]],
            "abstained": True,
            "abstention_reason": "DOMAIN_MECHANISM_NOT_DOMINANT_ENOUGH",
            "candidate_primary_type": winner["type"],
            "candidate_coverage": winner["coverage"],
            "dominance_scores": public_scores,
        }

    if not enough_dominance:
        return {
            "primary_type": UNKNOWN,
            "confidence": 0.79,
            "supporting_mechanisms": [m["kind"] for m in winner["mechanisms"]],
            "abstained": True,
            "abstention_reason": "COMPETING_DOMAIN_MECHANISMS",
            "candidate_primary_type": winner["type"],
            "candidate_margin": round(margin, 4),
            "dominance_scores": public_scores,
        }

    confidence = min(
        0.99,
        0.78
        + min(0.10, winner["coverage"] * 0.25)
        + min(0.06, max(0, winner["independent_support"] - 1) * 0.03)
        + min(0.05, max(0.0, margin) / 200.0),
    )
    # Contract-agent integration requires >= .90 before overriding.
    # A resolved dominant primary is intentionally promoted into that band.
    confidence = max(0.90, confidence)

    return {
        "primary_type": winner["type"],
        "confidence": round(confidence, 4),
        "supporting_mechanisms": [m["kind"] for m in winner["mechanisms"]],
        "abstained": False,
        "abstention_reason": None,
        "primary_evidence_coverage": winner["coverage"],
        "dominance_margin": round(margin, 4),
        "dominance_scores": public_scores,
    }

def build_semantic_source_profile(source_text: str, language: str | None = None) -> dict:
    source = str(source_text or "")
    lang = language or detect_source_language(source)
    extracted = extract_source_mechanisms(source, lang)
    grounded = ground_mechanisms(source, extracted)
    grounded = materialize_normalized_relations(
        grounded,
        source,
    )
    ranked = rank_material_mechanisms(grounded)
    primary = derive_primary_type_from_ranked_mechanisms(ranked, source_length=len(source))
    profile = {
        "profile_version": "shadow-p0-v4.1.12-cybersecurity",
        "source_language": lang,
        "source_text_hash": hashlib.sha256(source.encode("utf-8")).hexdigest(),
        "extracted_mechanisms": extracted,
        "grounded_mechanisms": grounded,
        "ranked_material_mechanisms": ranked,
        **primary,
    }
    profile["semantic_profile_hash"] = _hash_json({
        "source_language": profile["source_language"],
        "ranked_material_mechanisms": profile["ranked_material_mechanisms"],
        "primary_type": profile["primary_type"],
        "abstained": profile["abstained"],
        "dominance_scores": profile.get("dominance_scores", []),
    })
    return profile

def canonicalize_pipeline_type(value: str | None) -> str:
    normalized = str(value or "").strip().lower()
    return _TYPE_EQUIVALENCE.get(normalized, normalized or UNKNOWN.lower())
