def clause_display_title(
    clause: dict,
    language: str = "en",
) -> str:
    language = normalize_language(language)

    title = normalize_report_text(
        clause.get("title")
        or clause.get("clause_title")
        or clause.get("clause_type")
        or ""
    )

    if title:
        return title

    fallbacks = {
        "en": "Contract provision",
        "fr": "Disposition contractuelle",
        "ar": "حكم تعاقدي",
    }
    return fallbacks[language]


def clean_clause_lead(
    text: str,
    language: str = "en",
) -> str:
    language = normalize_language(language)
    text = normalize_report_text(text)

    if not text:
        return ""

    prefixes = {
        "en": (
            "This clause ",
            "The clause ",
        ),
        "fr": (
            "Cette clause ",
            "La clause ",
        ),
        "ar": (
            "ينص هذا البند على ",
            "يحدد هذا البند ",
            "يتناول هذا البند ",
            "هذا البند ",
        ),
    }

    for prefix in prefixes[language]:
        if text.lower().startswith(prefix.lower()):
            text = text[len(prefix):].strip()
            if text:
                text = text[0].upper() + text[1:] if language != "ar" else text
            break

    return text


def title_aware_clause_text(
    clause: dict,
    language: str = "en",
) -> str:
    title = clause_display_title(clause, language)
    insight = clean_clause_lead(
        clause.get("why_it_matters")
        or clause.get("business_impact")
        or clause.get("commercial_impact")
        or clause.get("operational_impact")
        or clause.get("risk_reason")
        or clause.get("legal_insight")
        or clause.get("explanation_simple")
        or "",
        language,
    )

    if not insight or is_generic_report_text(insight, language):
        return ""

    separator = " — " if language != "ar" else " — "
    return f"{title}{separator}{insight}"


def classify_legacy_section_role(
    clause: dict,
) -> str:
    clause_type = normalize_family_name_for_optional_fields(
        clause.get("clause_type", "")
    )
    text = safe_get_text(
        clause_type,
        clause.get("title"),
        clause.get("clause_title"),
    ).lower()

    obligation_score = sum(
        1
        for marker in OBLIGATION_TYPE_MARKERS
        if marker in text
    )
    key_point_score = sum(
        1
        for marker in KEY_POINT_TYPE_MARKERS
        if marker in text
    )

    if obligation_score > key_point_score:
        return "obligation"

    if key_point_score > obligation_score:
        return "key_point"

    # Conservative default: high/medium risk allocation or structural clauses
    # belong in key points; operational duties belong in obligations.
    if str(clause.get("risk_level", "")).lower() == "high":
        return "key_point"

    return "obligation"


def build_legacy_clause_sections(
    report: dict,
    language: str = "en",
) -> tuple[list[str], list[str]]:
    language = normalize_language(language)

    obligation_items = []
    key_point_items = []

    for clause in report.get("key_clauses", []) or []:
        if not isinstance(clause, dict):
            continue

        item = title_aware_clause_text(
            clause,
            language,
        )
        if not item:
            continue

        role = classify_legacy_section_role(clause)
        if role == "key_point":
            key_point_items.append(item)
        else:
            obligation_items.append(item)

    obligations = compact_unique_texts(
        obligation_items,
        language,
        limit=8,
        drop_generic=True,
    )
    key_points = compact_unique_texts(
        key_point_items,
        language,
        limit=8,
        drop_generic=True,
    )

    # Keep sections informative even where a contract family contains mostly
    # one role class, without duplicating identical bullets across sections.
    obligation_keys = {report_text_key(item) for item in obligations}

    if not key_points:
        key_points = compact_unique_texts(
            [
                item
                for item in obligation_items + key_point_items
                if report_text_key(item) not in obligation_keys
            ],
            language,
            limit=8,
            drop_generic=True,
        )

    key_point_keys = {report_text_key(item) for item in key_points}

    if not obligations:
        obligations = compact_unique_texts(
            [
                item
                for item in obligation_items + key_point_items
                if report_text_key(item) not in key_point_keys
            ],
            language,
            limit=8,
            drop_generic=True,
        )

    return obligations, key_points


def english_indefinite_article(value: str) -> str:
    word = normalize_report_text(value)
    if not word:
        return "a"

    # Adequate for legal family labels such as NDA, Agreement, Employment,
    # Outsourcing, IP Assignment, etc. Acronym vowel-sound exceptions are
    # handled explicitly.
    upper = word.upper()
    if upper.startswith(("NDA", "MSA", "SLA", "SPA", "LLC", "FCA")):
        return "an"

    return "an" if word[0].lower() in "aeiou" else "a"


