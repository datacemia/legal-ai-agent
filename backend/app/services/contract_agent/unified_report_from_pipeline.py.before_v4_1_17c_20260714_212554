def report_text_key(value: str) -> str:
    value = normalize_report_text(value).lower()
    value = re.sub(r"[^\w\u0600-\u06ff]+", " ", value, flags=re.UNICODE)
    return " ".join(value.split())


def is_generic_report_text(
    value: str,
    language: str = "en",
) -> bool:
    language = normalize_language(language)
    lowered = normalize_report_text(value).lower()
    if not lowered:
        return True

    markers = GENERIC_REPORT_TEXT_MARKERS.get(
        language,
        GENERIC_REPORT_TEXT_MARKERS["en"],
    )
    return any(marker in lowered for marker in markers)


def compact_unique_texts(
    values,
    language: str = "en",
    limit: int = 6,
    drop_generic: bool = True,
) -> list[str]:
    output = []
    seen = set()

    for value in values or []:
        text = normalize_report_text(value)
        if not text:
            continue
        if drop_generic and is_generic_report_text(text, language):
            continue

        key = report_text_key(text)
        if not key or key in seen:
            continue

        seen.add(key)
        output.append(text)

        if len(output) >= max(1, int(limit or 1)):
            break

    return output


def is_substantive_overview_value(
    value,
    language: str = "en",
) -> bool:
    language = normalize_language(language)
    text = normalize_report_text(value)

    if not text:
        return False

    defaults = {
        normalize_report_text(localized_default("not_specified", language)).lower(),
        normalize_report_text(localized_default("not_applicable", language)).lower(),
        "unknown",
        "inconnu",
        "غير معروف",
    }
    return text.lower() not in defaults


GOVERNING_LAW_PATTERNS = {
    "en": (
        r"\b(?:governed by|governed and construed in accordance with|construed in accordance with)\s+(?:the\s+)?laws?\s+of\s+([^.;\n]{2,120})",
        r"\bexclusive jurisdiction\s+of\s+(?:the\s+)?([^.;\n]{2,120}?)(?:\s+for\s+the\s+resolution|\s+for\s+resolution|[.;\n])",
    ),
    "fr": (
        r"\b(?:régi|regi)\s+par\s+(?:les?\s+)?(?:lois?|droit)\s+de\s+([^.;\n]{2,120})",
        r"\bjuridiction\s+exclusive\s+(?:des?|de\s+la)\s+([^.;\n]{2,120})",
    ),
    "ar": (
        r"(?:يخضع|تخضع).{0,40}(?:لقانون|لقوانين)\s+([^.;؛!؟\n]{2,120})",
        r"(?:الاختصاص\s+الحصري|الولاية\s+القضائية\s+الحصرية).{0,40}(?:لـ|ل)\s*([^.;؛!؟\n]{2,120})",
    ),
}


def extract_document_jurisdiction(
    contract_text: str,
    language: str = "en",
) -> str | None:
    language = normalize_language(language)
    text = str(contract_text or "")

    for pattern in GOVERNING_LAW_PATTERNS[language]:
        match = re.search(pattern, text, flags=re.IGNORECASE)
        if not match:
            continue

        value = normalize_report_text(match.group(1)).strip(" ,،")
        value = re.split(
            r"\bwithout\s+regard\b|\bsubject\s+to\b"
            r"|\bsans\s+égard\b|\bsous\s+réserve\b"
            r"|(?:دون\s+اعتبار|مع\s+مراعاة)",
            value,
            maxsplit=1,
            flags=re.IGNORECASE,
        )[0].strip(" ,،")

        if 2 <= len(value) <= 120:
            return value

    return None


def build_contract_quality_score(
    pipeline_result: dict,
    clauses: list,
) -> int:
    """
    Deterministic analysis-quality score.

    This is intentionally independent from contractual risk. It measures
    analysis coverage and confidence, so a low-risk contract cannot be
    mislabeled as a low-quality contract merely because both use 0-100 scales.
    """
    if not clauses:
        return 0

    confidence_points = {
        "high": 1.0,
        "medium": 0.72,
        "low": 0.35,
    }

    confidence_values = [
        confidence_points.get(
            str(clause.get("confidence") or "medium").lower(),
            0.55,
        )
        for clause in clauses
        if isinstance(clause, dict)
    ]

    average_confidence = (
        sum(confidence_values) / len(confidence_values)
        if confidence_values else 0.0
    )

    total_detected = (
        pipeline_result.get("total_clauses_detected")
        or len(clauses)
    )
    analyzed = (
        pipeline_result.get("clauses_analyzed")
        or len(clauses)
    )

    try:
        coverage = min(
            1.0,
            max(0.0, float(analyzed) / max(float(total_detected), 1.0)),
        )
    except (TypeError, ValueError, ZeroDivisionError):
        coverage = 1.0

    fidelity_failures = sum(
        1
        for clause in clauses
        if isinstance(clause, dict)
        and any(
            marker in safe_get_text(
                clause.get("legal_insight"),
                clause.get("recommendation"),
                clause.get("negotiation_advice"),
                clause.get("safer_alternative"),
            ).lower()
            for marker in (
                "manual review required",
                "examen manuel requis",
                "مراجعة يدوية مطلوبة",
            )
        )
    )

    fidelity_ratio = max(
        0.0,
        1.0 - (fidelity_failures / max(len(clauses), 1)),
    )

    score = round(
        (average_confidence * 60)
        + (coverage * 25)
        + (fidelity_ratio * 15)
    )

    return max(0, min(100, score))


