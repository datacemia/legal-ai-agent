def canonical_family_key(value: str) -> str:
    normalized = normalize_family_name_for_optional_fields(value)

    for canonical, aliases in CANONICAL_FAMILY_ALIASES.items():
        if normalized in aliases:
            return canonical

    return normalized


def roles_are_reciprocal_or_contextual(
    parties: list[str],
    language: str = "en",
) -> bool:
    language = normalize_language(language)
    markers = RECIPROCAL_ROLE_MARKERS[language]

    normalized = {
        normalize_role_label(item)
        for item in parties
        if str(item or "").strip()
    }

    return bool(normalized & markers)


def canonicalize_party_labels(
    parties,
    language: str = "en",
) -> list[str]:
    """
    International party-display invariant.

    Stable asymmetric legal roles remain unchanged.
    Reciprocal/context-dependent roles become neutral Party A / Party B.
    Missing, duplicate, or generic structural labels also become Party A / Party B.

    This policy does not inspect contract names or company names.
    """
    language = normalize_language(language)
    generic = list(GENERIC_PARTY_LABELS[language])

    if isinstance(parties, str):
        parties = [parties]
    elif not isinstance(parties, list):
        parties = []

    cleaned = [
        str(item or "").strip()
        for item in parties
        if str(item or "").strip()
    ]

    if len(cleaned) < 2:
        return generic

    first_two = cleaned[:2]
    normalized = [normalize_role_label(item) for item in first_two]

    if any(item in PLACEHOLDER_PARTY_VALUES for item in normalized):
        return generic

    if normalized[0] == normalized[1]:
        return generic

    if roles_are_reciprocal_or_contextual(first_two, language):
        return generic

    return first_two


