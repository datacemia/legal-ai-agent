TYPE_PRIORITY = {
    "consent_control": 100,
    "termination": 98,
    "renewal": 96,
    "financial_reporting": 88,
    "corporate_governance": 86,
    "liability": 84,
    "confidentiality": 80,
    "mandatory_obligation": 40,
    "prohibition": 35,
    "express_right": 30,
}

_TYPE_EQUIVALENCE = {
    "investor_information_rights": "financial_reporting",
    "information_rights": "financial_reporting",
    "limitation_of_liability": "liability",
    "automatic_renewal": "renewal",
    "term_and_termination": "termination",
    "governance": "corporate_governance",
}


def _hash_json(value: Any) -> str:
    payload = json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()


def _normalize_for_language_detection(text: str) -> str:
    return unicodedata.normalize("NFKC", str(text or ""))


def detect_source_language(text: str) -> str:
    value = _normalize_for_language_detection(text)
    if re.search(r"[\u0600-\u06FF]", value):
        return "ar"
    if re.search(r"[àâçéèêëîïôùûüÿœæ]", value.lower()):
        return "fr"
    french_markers = re.findall(
        r"\b(?:le|la|les|des|une|du|aux|doit|sans|droit|délai|contrat|partie)\b",
        value.lower(),
    )
    return "fr" if len(french_markers) >= 3 else "en"


def _evidence(source: str, pattern: str, label: str) -> Iterable[dict]:
    for match in re.finditer(pattern, source, re.IGNORECASE | re.DOTALL):
        yield {
            "label": label,
            "start": match.start(),
            "end": match.end(),
            "text": match.group(0),
        }


def _valid_span(source: str, span: dict) -> bool:
    start = span.get("start")
    end = span.get("end")
    text = span.get("text")
    return (
        isinstance(start, int)
        and isinstance(end, int)
        and 0 <= start < end <= len(source)
        and source[start:end] == text
    )


def _mandatory_arguments(span_text: str, language: str) -> list[dict]:
    if language == "ar":
        parts = re.split(r"\s+و(?=[\u0600-\u06FF])|،", span_text)
    elif language == "fr":
        parts = re.split(r"\s+et\s+", span_text, flags=re.IGNORECASE)
    else:
        parts = re.split(r"\s+and\s+", span_text, flags=re.IGNORECASE)

    result = []
    for part in parts:
        tokens = re.findall(r"[^\W\d_]{3,}", part.lower(), flags=re.UNICODE)
        if tokens:
            result.append({"text": part.strip(), "tokens": tokens[:20]})
    return result if len(result) >= 2 else []


def extract_source_mechanisms(source_text: str, language: str | None = None) -> list[dict]:
    source = str(source_text or "")
    lang = language or detect_source_language(source)
    mechanisms: list[dict] = []

    for rule in RULES:
        spans: list[dict] = []
        for pattern in rule.patterns.get(lang, ()):
            spans.extend(_evidence(source, pattern, rule.kind))

        if not spans:
            continue

        unique_spans = []
        seen = set()
        for span in spans:
            key = (span["start"], span["end"], span["label"])
            if key not in seen and _valid_span(source, span):
                seen.add(key)
                unique_spans.append(span)

        if not unique_spans:
            continue

        mechanism: dict[str, Any] = {
            "kind": rule.kind,
            "rank": rule.rank,
            "candidate_primary_type": rule.primary_type,
            "source_evidence": unique_spans,
            "grounded": True,
        }
        if rule.polarity:
            mechanism["polarity"] = rule.polarity
        if rule.procedural_state:
            mechanism["procedural_state"] = rule.procedural_state
        if rule.kind == "MANDATORY_CONJUNCTION":
            arguments = _mandatory_arguments(unique_spans[0]["text"], lang)
            if arguments:
                mechanism["arguments"] = arguments
            else:
                mechanism["kind"] = "MANDATORY_OBLIGATION"
                mechanism["rank"] = 72
        mechanisms.append(mechanism)

    return mechanisms


def attach_source_evidence(source_text: str, mechanisms: list[dict]) -> list[dict]:
    source = str(source_text or "")
    grounded: list[dict] = []
    for mechanism in mechanisms:
        spans = mechanism.get("source_evidence") or []
        valid = [span for span in spans if isinstance(span, dict) and _valid_span(source, span)]
        if not valid:
            continue
        item = dict(mechanism)
        item["source_evidence"] = valid
        item["grounded"] = True
        item["evidence_hash"] = _hash_json(valid)
        grounded.append(item)
    return grounded


def ground_mechanisms(source_text: str, mechanisms: list[dict]) -> list[dict]:
    return attach_source_evidence(source_text, mechanisms)


def rank_material_mechanisms(grounded_mechanisms: list[dict]) -> list[dict]:
    material = [
        dict(mechanism)
        for mechanism in grounded_mechanisms
        if mechanism.get("grounded") is True
        and mechanism.get("source_evidence")
        and int(mechanism.get("rank", 0)) >= 70
    ]
    material.sort(
        key=lambda item: (
            -int(item.get("rank", 0)),
            str(item.get("kind", "")),
            int(item["source_evidence"][0]["start"]),
        )
    )
    return material


def derive_primary_type_from_ranked_mechanisms(ranked_mechanisms: list[dict]) -> dict:
    candidates: dict[str, dict] = {}
    for mechanism in ranked_mechanisms:
        candidate = str(mechanism.get("candidate_primary_type") or "")
        if not candidate:
            continue
        score = max(int(mechanism.get("rank", 0)), TYPE_PRIORITY.get(candidate, 0))
        current = candidates.get(candidate)
        if current is None or score > current["score"]:
            candidates[candidate] = {
                "type": candidate,
                "score": score,
                "supporting_mechanism": mechanism.get("kind"),
            }

    if not candidates:
        return {
            "primary_type": UNKNOWN,
            "confidence": 0.0,
            "supporting_mechanisms": [],
            "abstained": True,
        }

    ordered = sorted(candidates.values(), key=lambda item: (-item["score"], item["type"]))
    winner = ordered[0]
    support = [
        mechanism["kind"]
        for mechanism in ranked_mechanisms
        if mechanism.get("candidate_primary_type") == winner["type"]
    ]
    return {
        "primary_type": winner["type"],
        "confidence": round(min(0.99, 0.50 + winner["score"] / 200), 4),
        "supporting_mechanisms": support,
        "abstained": False,
    }


def build_semantic_source_profile(source_text: str, language: str | None = None) -> dict:
    source = str(source_text or "")
    lang = language or detect_source_language(source)
    extracted = extract_source_mechanisms(source, lang)
    grounded = ground_mechanisms(source, extracted)
    ranked = rank_material_mechanisms(grounded)
    primary = derive_primary_type_from_ranked_mechanisms(ranked)

    profile = {
        "profile_version": "shadow-p0-v1",
        "source_language": lang,
        "source_text_hash": hashlib.sha256(source.encode("utf-8")).hexdigest(),
        "extracted_mechanisms": extracted,
        "grounded_mechanisms": grounded,
        "ranked_material_mechanisms": ranked,
        **primary,
    }
    profile["semantic_profile_hash"] = _hash_json({
        "source_language": profile["source_language"],
        "ranked_material_mechanisms": profile["ranked_material_mechanisms"],
        "primary_type": profile["primary_type"],
        "abstained": profile["abstained"],
    })
    return profile


def canonicalize_pipeline_type(value: str | None) -> str:
    normalized = str(value or "").strip().lower()
    return _TYPE_EQUIVALENCE.get(normalized, normalized or UNKNOWN.lower())
