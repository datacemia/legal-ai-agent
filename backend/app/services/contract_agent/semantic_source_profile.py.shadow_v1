"""Independent source-semantic profile builder.

Shadow-mode component for P0 semantic correctness work.

Design invariants:
- exact source text is the only semantic input;
- canonical mechanism names are language-neutral;
- every material mechanism carries exact source evidence;
- evidence is validated against source offsets;
- unsupported/ungrounded mechanisms are never ranked material;
- primary type is derived from ranked grounded mechanisms;
- uncertainty abstains as UNKNOWN rather than inventing a type.

This module does not import or modify publication_gate.py.
"""
from __future__ import annotations

import hashlib
import json
import re
import unicodedata
from dataclasses import dataclass
from typing import Any, Iterable


UNKNOWN = "UNKNOWN"


@dataclass(frozen=True)
class MechanismRule:
    kind: str
    patterns: dict[str, tuple[str, ...]]
    rank: int
    primary_type: str
    polarity: str | None = None
    procedural_state: str | None = None


RULES: tuple[MechanismRule, ...] = (
    MechanismRule(
