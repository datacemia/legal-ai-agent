            ),
            "ar": (
                r"(?:يجب|يتعين|يلتزم).{0,80}(?:الحفاظ|المحافظة).{0,80}(?:سرية|سري).{0,180}",
            ),
        },
        80,
        "confidentiality",
        polarity="REQUIRED",
    ),
