"""Language-neutral normalized legal relation materialization.

This module projects already-grounded canonical source mechanisms into a
stable relation schema. It does not classify clauses or generate legal text.
"""

from __future__ import annotations

import re
from typing import Any


UNKNOWN = "UNKNOWN"


