def walk(obj: Any):
    if isinstance(obj, dict):
        yield obj
        for value in obj.values():
            yield from walk(value)
    elif isinstance(obj, list):
        for value in obj:
            yield from walk(value)

def clause_results(payload: Any) -> list[dict[str, Any]]:
    if isinstance(payload, dict):
        clauses = payload.get("clauses")
        if isinstance(clauses, dict) and isinstance(clauses.get("results"), list):
            return [x for x in clauses["results"] if isinstance(x, dict)]
        if isinstance(payload.get("results"), list):
            return [x for x in payload["results"] if isinstance(x, dict)]
    return [x for x in walk(payload) if "_source_text_exact" in x and ("clause_type" in x or "primary_type" in x)]

def source(item: dict[str, Any]) -> str:
    return str(item.get("_source_text_exact") or item.get("original_text") or item.get("clause_text") or item.get("quoted_text") or "")

def primary_type(item: dict[str, Any]) -> str:
    return str(item.get("primary_type") or item.get("clause_type") or item.get("type") or "").strip().lower()

def actual_mechanisms(item: dict[str, Any]) -> list[dict[str, Any]]:
    """Read the richest persisted semantic mechanism set before fidelity fallbacks."""
    containers = [
        item,
        item.get("_semantic_source_profile"),
        item.get("semantic_source_profile"),
        item.get("source_semantic_profile"),
        item.get("source_profile"),
    ]

    for key in ("ranked_material_mechanisms", "grounded_mechanisms", "extracted_mechanisms"):
        for container in containers:
            if isinstance(container, dict) and isinstance(container.get(key), list):
                values = [x for x in container[key] if isinstance(x, dict)]
                if values:
                    return values

    profile = item.get("source_evidence_model")
    if isinstance(profile, dict) and isinstance(profile.get("mechanisms"), list):
        return [x for x in profile["mechanisms"] if isinstance(x, dict)]
    return []

